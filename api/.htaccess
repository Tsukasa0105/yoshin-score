# Protect vendor and data directories
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^vendor/ - [F,L]
  RewriteRule ^data/ - [F,L]
</IfModule>

# Only allow analyze.php and history.php
<FilesMatch "^(?!analyze|history).*\.php$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Protect sensitive files from web access
<FilesMatch "^(composer\.(json|lock)|\.env.*|php\.ini)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Set upload limits (override php.ini if possible)
<IfModule mod_php.c>
  php_value upload_max_filesize 20M
  php_value post_max_size 22M
  php_value max_execution_time 180
  php_value memory_limit 256M
</IfModule>
